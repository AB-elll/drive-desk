# ===========================================
# DriveDesk Environment Variables
# Values stored in Bitwarden (AIG-Secrets folder)
# Restore: export BW_SESSION=$(bw unlock --raw)
# ===========================================

# freee OAuth App
FREEE_CLIENT_ID=
# bw get notes freee-client-id

FREEE_CLIENT_SECRET=
# bw get notes freee-client-secret

FREEE_COMPANY_ID=
# bw get notes freee-company-id

# Google OAuth Configuration
GOOGLE_OAUTH_TOKENS_PATH=~/.config/drivedesk/google_tokens.json
GOOGLE_OAUTH_KEYS_PATH=~/.config/gogcli/credentials.json

# Google Drive & Spreadsheet
LOG_SPREADSHEET_ID=
# bw get notes log-spreadsheet-id

GOOGLE_DRIVE_FOLDER_ID=1ORIn57kxknDbDuU4dci4_Sq-4Dq3xZa1